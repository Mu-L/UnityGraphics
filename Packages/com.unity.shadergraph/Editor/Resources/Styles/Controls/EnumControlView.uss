EnumControlView {
    flex-direction: row;
    align-items: center;
    padding-left: 8px;
    padding-right: 5px;
    max-width: 200px;
}

.unity-base-field {
    min-width: 80px;
    margin-top: 4px;
    margin-bottom: 4px;
}

.unity-base-field__input {
    margin-left: 0;
}

EnumControlView > Label {
    min-width: 30px;
    -unity-text-align: middle-left;
    flex-grow: 1;
    padding-right: 8px;
}
