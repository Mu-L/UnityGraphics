*.unity                 filter=lfs diff=lfs-text merge=lfs-text -text
*.vfx                   filter=lfs diff=lfs-text merge=lfs-text -text

# this particular ext has many variations
*.[fF][bB][xX].meta                 filter=lfs diff=lfs-text merge=lfs-text -text

