##############
# WINDOWS-ISMS
##############

# vs can handle these as lf, but resets to crlf if it modifies them. let's not fight it.
*.bat                    eol=crlf
*.cmd                    eol=crlf
*.csproj                 eol=crlf
*.props                  eol=crlf
*.sln                    eol=crlf
*.sln.template           eol=crlf
*.targets                eol=crlf
*.vcproj                 eol=crlf
